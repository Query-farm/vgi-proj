# name: test/sql/transform.test
# description: CRS transforms -- web mercator, transform round-trip, to_utm, NULL / unknown-CRS handling
# group: [vgi_proj]

require-env VGI_PROJ_WORKER

statement ok
LOAD vgi;

statement ok
ATTACH 'proj' AS proj (TYPE vgi, LOCATION '${VGI_PROJ_WORKER}');

# Web Mercator origin: (0, 0) -> (0, 0).
query I
SELECT ROUND((proj.to_webmercator(0.0, 0.0)).x, 0);
----
0

query I
SELECT ROUND((proj.to_webmercator(0.0, 0.0)).y, 0);
----
0

# San Francisco in Web Mercator (metres), rounded to the nearest 100 m.
query I
SELECT ROUND((proj.to_webmercator(-122.4194, 37.7749)).x / 100.0) * 100
       BETWEEN -13628000 AND -13627400;
----
true

# transform(EPSG:4326 -> EPSG:3857) matches to_webmercator.
query I
SELECT ROUND((proj.transform(-122.42, 37.77, 'EPSG:4326', 'EPSG:3857')).x, 3)
     = ROUND((proj.to_webmercator(-122.42, 37.77)).x, 3);
----
true

# Round-trip lon/lat -> web mercator -> lon/lat recovers the input within tolerance.
query I
SELECT ROUND((proj.from_webmercator(
                (proj.to_webmercator(-122.4194, 37.7749)).x,
                (proj.to_webmercator(-122.4194, 37.7749)).y)).lon, 4) = -122.4194;
----
true

# to_utm auto-picks zone 10, northern hemisphere, for San Francisco.
query I
SELECT (proj.to_utm(-122.42, 37.77)).zone;
----
10

query I
SELECT (proj.to_utm(-122.42, 37.77)).hemisphere;
----
N

# NULL coordinate -> NULL struct.
query I
SELECT proj.to_webmercator(NULL, 37.77) IS NULL;
----
true

query I
SELECT proj.to_utm(-122.42, NULL) IS NULL;
----
true

# Unknown CRS -> clear error (not a crash).
statement error
SELECT proj.transform(0.0, 0.0, 'EPSG:4326', 'NOT_A_CRS');
----

statement ok
DETACH proj;
